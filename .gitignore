# Ignore runtime-generated files
hostapd.conf
dnsmasq.conf
server.log
__pycache__/
*.pyc

# Ignore the education content directory
/education_content/

# Ignore private SSL keys and certs
ssl/key.pem
ssl/cert.pem
ssl/*.key
ssl/*.pem

# Ignore NextCloud runtime data (created by docker volumes)
nextcloud/html/
nextcloud/custom_apps/
nextcloud/config/
nextcloud/data/
nextcloud/nextclouddb/
nextcloud/redis/
nextcloud/npm-data/
nextcloud/letsencrypt/
