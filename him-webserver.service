[Unit]
Description=HIM Education Captive Portal Web Server
After=network.target him-ap.service him-firewall.service
Wants=him-ap.service him-firewall.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 /home/him/walled_garden/server.py
WorkingDirectory=/home/him/walled_garden
Restart=always
RestartSec=3
User=root

[Install]
WantedBy=multi-user.target